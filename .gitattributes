# Binary files
*.pkl binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.webp binary

# Text files
*.js text
*.jsx text
*.json text
*.md text
*.yml text
*.yaml text
*.dockerfile text
Dockerfile text
*.conf text
*.sql text
*.py text
*.html text
*.css text
*.sh text
*.txt text

# End of line normalization
* text=auto eol=lf

# Large files - use LFS if needed
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
