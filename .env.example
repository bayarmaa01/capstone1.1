# ================================
# DATABASE
# ================================

# Local development database
DATABASE_URL=postgresql://app:secret@localhost:5432/attendance

# Production Azure database (replace with actual values)
# DATABASE_URL=postgresql://username:password@server.postgres.database.azure.com:5432/attendance

# ================================
# SERVER
# ================================

PORT=4000
NODE_ENV=development

# ================================
# SECURITY
# ================================

# Generate secure random string: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters-long

# ================================
# MOODLE LMS INTEGRATION
# ================================

# Moodle Web Service API Configuration
MOODLE_URL=http://moodle/webservice/rest/server.php
MOODLE_TOKEN=your-moodle-api-token-here
MOODLE_WS_TOKEN=your-moodle-api-token-here

# Moodle OAuth2 (Optional)
MOODLE_CLIENT_ID=your-moodle-oauth-client-id
MOODLE_CLIENT_SECRET=your-moodle-oauth-client-secret
MOODLE_REDIRECT_URI=https://attendance-ml.duckdns.org/auth/callback

# ================================
# FRONTEND
# ================================

FRONTEND_URL=https://attendance-ml.duckdns.org
REACT_APP_API_URL=https://attendance-ml.duckdns.org/api
REACT_APP_FACE_SERVICE_URL=https://attendance-ml.duckdns.org/face

# ================================
# AZURE STORAGE
# ================================

# Replace with your Azure Storage connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-storage-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=face-images

# ================================
# FACE SERVICE
# ================================

# Legacy face service URL (for backward compatibility)
FACE_SERVICE_URL=http://face-service:5001

# ================================
# DEVELOPMENT OVERRIDES
# ================================

# Uncomment for local development
# REACT_APP_API_URL=http://localhost:4000
# REACT_APP_FACE_SERVICE_URL=http://localhost:5001